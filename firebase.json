{
    "hosting": {
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "firestore": [
        {
            "database": "(default)",
            "rules": "firestore.rules",
            "indexes": "firestore.indexes.json"
        },
        {
            "database": "hr-saas-db-prod",
            "rules": "firestore.rules",
            "indexes": "firestore.indexes.json"
        }
    ]
}