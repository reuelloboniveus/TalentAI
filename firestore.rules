rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Safe Helper functions
    function hasUserData() {
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return hasUserData() ? getUserData().get('role', '') : '';
    }

    function isSuperAdmin() {
      return getUserRole() == 'super_admin';
    }

    function getUserOrgId() {
      return hasUserData() ? getUserData().get('orgId', '') : '';
    }

    // User rules
    match /users/{userId} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        getUserRole() in ['admin', 'super_admin']
      );
      
      match /history/{historyId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId ||
          getUserRole() in ['admin', 'super_admin']
        );
      }

      match /jds/{jdId} {
        allow read, write: if request.auth != null && (
          request.auth.uid == userId ||
          isSuperAdmin()
        );
      }
    }
    
    // Organization rules
    match /organizations/{orgId} {
      // Allow any authenticated user to create an org (they become owner)
      allow create: if request.auth != null;
      
      // Allow read/update if owner, member, or SUPER ADMIN
      allow read, update: if request.auth != null && (
        resource.data.ownerId == request.auth.uid ||
        getUserOrgId() == orgId ||
        isSuperAdmin()
      );

      match /jds/{jdId} {
        allow read, write: if request.auth != null && (
          getUserOrgId() == orgId ||
          isSuperAdmin()
        );
      }
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

